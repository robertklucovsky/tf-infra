{
  "id": "fatto",
  "realm": "fatto",
  "displayName": "FATTO",
  "displayNameHtml": "<strong>FATTO</strong> Manufacturing ERP",
  "enabled": true,
  "sslRequired": "external",
  "loginTheme": "fatto",
  "accountTheme": "keycloak.v2",
  "adminTheme": "keycloak.v2",
  "emailTheme": "keycloak",
  "internationalizationEnabled": true,
  "supportedLocales": [
    "en",
    "sk",
    "cs"
  ],
  "defaultLocale": "en",
  "registrationAllowed": false,
  "registrationEmailAsUsername": true,
  "rememberMe": true,
  "resetPasswordAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "verifyEmail": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "accessTokenLifespan": 43200,
  "accessTokenLifespanForImplicitFlow": 43200,
  "ssoSessionIdleTimeout": 43200,
  "ssoSessionMaxLifespan": 86400,
  "offlineSessionIdleTimeout": 2592000,
  "offlineSessionMaxLifespan": 5184000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,
  "roles": {
    "realm": [
      {
        "name": "fatto:super-admin",
        "description": "Cross-tenant platform operator — full access to all tenants"
      },
      {
        "name": "fatto:tenant-admin",
        "description": "Full administrative access within own tenant"
      },
      {
        "name": "fatto:product-manager",
        "description": "CRUD on products, BOMs, and product variants"
      },
      {
        "name": "fatto:sales-rep",
        "description": "CRUD on orders/quotes, read products"
      },
      {
        "name": "fatto:warehouse-op",
        "description": "Inventory management and stock movements"
      },
      {
        "name": "fatto:viewer",
        "description": "Read-only access across tenant resources"
      }
    ]
  },
  "groups": [
    {
      "name": "tenant:atlas",
      "attributes": {
        "tenant_id": [
          "00000000-0000-0000-0000-000000000001"
        ],
        "tenant_name": [
          "Atlas Manufacturing Group"
        ],
        "tier": [
          "enterprise"
        ],
        "features": [
          "basic-products,basic-orders,bom-management,reporting,ai-assistant,api-access"
        ]
      },
      "realmRoles": [
        "fatto:viewer"
      ]
    },
    {
      "name": "tenant:nova",
      "attributes": {
        "tenant_id": [
          "00000000-0000-0000-0000-000000000002"
